generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===========================================
// Modelagem do Banco de Dados para o Sistema de Doações
// ===========================================

model Voluntario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  admin     Boolean  @default(false)
  senha     String
  endereco  String?
  telefone  String?
  createdAt DateTime @default(now()) @map("dataCriacao")
  updatedAt DateTime @updatedAt @map("dataAtualizacao")

  doacoes       Doacao[]
  distribuicoes Distribuicao[]
}

model CartaoBeneficiario {
  id              Int      @id @default(autoincrement())
  numeroCartao    String   @unique
  dataValidade    DateTime
  ativo           Boolean  @default(false)
  codigoSeguranca String   // Usado como senha de acesso do beneficiário no app
  beneficiarioId  Int      @unique
  createdAt       DateTime @default(now()) @map("dataCriacao")
  updatedAt       DateTime @updatedAt @map("dataAtualizacao")

  Beneficiario Beneficiario @relation("BeneficiarioToCartao", fields: [beneficiarioId], references: [id])
}

model Beneficiario {
  id        Int      @id @default(autoincrement())
  nome      String
  cpf       String   @unique
  telefone  String?
  endereco  String?
  limiteItens Int    @default(0) // Limite máximo de itens que o beneficiário pode receber (0 = sem limite)
  createdAt DateTime @default(now()) @map("dataCriacao")
  updatedAt DateTime @updatedAt @map("dataAtualizacao")

  distribuicoes Distribuicao[]
  cartoes       CartaoBeneficiario[] @relation("BeneficiarioToCartao")
}

model Doacao {
  id           Int      @id @default(autoincrement())
  voluntarioId Int
  createdAt    DateTime @default(now()) @map("dataCriacao")
  updatedAt    DateTime @updatedAt @map("dataAtualizacao")

  voluntario Voluntario   @relation(fields: [voluntarioId], references: [id])
  itens      ItemDoacao[]
}

model ItemDoacao {
  id         Int @id @default(autoincrement())
  quantidade Int
  doacaoId   Int
  itemId     Int

  doacao Doacao @relation(fields: [doacaoId], references: [id])
  item   Item   @relation(fields: [itemId], references: [id])
}

model Distribuicao {
  id             Int      @id @default(autoincrement())
  voluntarioId   Int
  beneficiarioId Int
  createdAt      DateTime @default(now()) @map("dataCriacao")
  updatedAt      DateTime @updatedAt @map("dataAtualizacao")

  voluntario   Voluntario         @relation(fields: [voluntarioId], references: [id])
  beneficiario Beneficiario       @relation(fields: [beneficiarioId], references: [id])
  itens        ItemDistribuicao[]
}

model ItemDistribuicao {
  id             Int @id @default(autoincrement())
  quantidade     Int
  distribuicaoId Int
  itemId         Int

  distribuicao Distribuicao @relation(fields: [distribuicaoId], references: [id])
  item         Item         @relation(fields: [itemId], references: [id])
}

model Item {
  id                Int      @id @default(autoincrement())
  quantidadeEstoque Int      @map("quantidade")
  condicaoId        Int
  tipoId            Int
  tamanhoId         Int
  createdAt         DateTime @default(now()) @map("dataCriacao")
  updatedAt         DateTime @updatedAt @map("dataAtualizacao")

  tipo     Tipo               @relation(fields: [tipoId], references: [id])
  tamanho  Tamanho            @relation(fields: [tamanhoId], references: [id])
  condicao Condicao           @relation(fields: [condicaoId], references: [id])
  entradas ItemDoacao[]
  saidas   ItemDistribuicao[]

  @@unique([tipoId, tamanhoId, condicaoId])
}

model Tipo {
  id        Int       @id @default(autoincrement())
  descricao String    @unique
  itens     Item[]
  tamanhos  Tamanho[]
}

model Tamanho {
  id        Int    @id @default(autoincrement())
  descricao String
  tipoId    Int

  tipo  Tipo   @relation(fields: [tipoId], references: [id])
  itens Item[]

  @@unique([descricao, tipoId])
}

model Condicao {
  id        Int    @id @default(autoincrement())
  descricao String @unique
  itens     Item[]
}
